ENVIRONMENT=development
DEBUG=true

# SQLite for dev. Switch to Postgres in prod:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/jaratrade
DATABASE_URL=sqlite:///./jaratrade.db

# JWT — REGENERATE for production: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-secret-change-me-in-production-please-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=10080

CORS_ORIGINS=["http://localhost:3000","http://localhost:3030","https://jaratrade.com"]

# Cloudinary (image uploads). Without these, the API falls back to base64 data-URLs.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Flutterwave. Without secrets the verify endpoint pretends success (dev only).
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPT_KEY=
FLW_COMMISSION_SUBACCOUNT_ID=

# SMTP — optional. Without these, emails print to stdout.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@jaratrade.com

SITE_URL=http://localhost:3030

# ────────── Observability ──────────

# Sentry — leave SENTRY_DSN blank to disable error tracking entirely.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# OpenTelemetry — three modes:
#   1. Both blank + ENVIRONMENT=development → console exporter (prints spans to stdout)
#   2. OTEL_EXPORTER_OTLP_ENDPOINT set       → ships traces to that OTLP/HTTP collector
#   3. OTEL_CONSOLE_EXPORTER=true            → force console even outside dev
OTEL_SERVICE_NAME=jaratrade-api
OTEL_EXPORTER_OTLP_ENDPOINT=
# Comma-separated key=value (e.g. `api-key=abc123,x-tenant=jaratrade`)
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_CONSOLE_EXPORTER=false
